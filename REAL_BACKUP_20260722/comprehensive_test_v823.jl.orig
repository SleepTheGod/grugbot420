))

# Scenario 15: Science lobe, :multi mode — multipart answer (pipe-delimited with mode prefixes)
# NOTE: content for :multi must be pipe-delimited ":mode1 text1 | :mode2 text2"
# GRUG v8.25: :multi now creates FULL CLUSTERS per part (_plant_answer_cluster)
# with fan-out shadow nodes that have query-matching patterns ("what is mitosis", etc.)
# so recall works when the original question is re-asked.
push!(answer_results, run_answer_scenario(
    "what is mitosis and why does it matter",
    "what is mitosis and why does it matter",
    "/answer @science :multi :define mitosis is cell division producing two identical daughter cells | :reason mitosis enables growth tissue repair and asexual reproduction",
    "science", "multi",
    ":define mitosis is cell division producing two identical daughter cells | :reason mitosis enables growth tissue repair and asexual reproduction"
))


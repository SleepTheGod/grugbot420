log_md("# /answer Mechanic Test (Teach-and-Reask with Lobes)")

# DEBUG: Check for auto-grown placeholder nodes that might interfere with /answer recall
let
    autogrown = lock(NODE_LOCK) do
        [(id, n.pattern, n.is_grave, get(n.json_data, "autogrowth_source", ""), get(n.json_data, "growth_source", "")) for (id, n) in NODE_MAP if !n.is_grave && !isempty(get(n.json_data, "autogrowth_source", ""))]
    end
    println("[DEBUG] Auto-grown nodes alive: $(length(autogrown))")
    for (id, pat, grave, auto_src, growth_src) in autogrown[1:min(5, length(autogrown))]
        println("  $id: pattern='$pat' auto_src='$auto_src'")
    end
end
log_md("")
println("─" ^ 70)
println("SECTION 14: /answer TEACH-AND-REASK")

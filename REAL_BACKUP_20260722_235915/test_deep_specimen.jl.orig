section("20. Petty Learner")

try
    result = classify_petty("hello", ["hello"], Set{String}(), (w)->String[], (a,b)->0.0, Tuple{String,String,Set{String}}[], Dict{String,Any}(), Dict{String,Any}())
    record("classify_petty('hello')", result !== nothing)
catch e

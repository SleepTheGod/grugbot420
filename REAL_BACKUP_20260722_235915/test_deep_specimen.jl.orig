# ══════════════════════════════════════════════════════════════
section("21. Input Decomposer")

try
    parts = decompose_input("what is 5+5 and what is love")
    record("decompose_input('what is 5+5 and what is love')", parts !== nothing, "parts=$(length(parts))")
catch e
    record("decompose_input", false, "$e")

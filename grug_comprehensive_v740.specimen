    ],
    "split_conjunctions": [
      "and",
      "or",
      "but",
      "then",
      "also",
      "plus",
      "however",
      "moreover",
      "furthermore",
      "additionally"
    ],
    "merge_split_conjunctions": true
  },
  "relational_jitter_config": {
    "default_ratio": 0.03,
    "coin_threshold_ratio": 0.05,
    "brainstorm_ratio": 0.1,
    "brainstorm_coin_ratio": 0.15,
    "strong_low_conf_override": true,
    "strong_low_conf_strength_floor": 7.5,
    "strong_low_conf_confidence_ceil": 0.35
  },
  "_comments": {
    "v759_nochat_singleton": "GRUG v7.59: Sigil nodes (node_type=sigil) are NOCHAT (ineligible for idle chatter) and singleton (never placed in growth groups). Their patterns are syntactic grammars (e.g. '&n &op &n'), not semantic content. ChatterVoteSwap must not remix their deterministic execution chains. People don't dream in procedures. IMPORTANT: Relational triples can optionally USE sigils, making them dynamic rather than static. A required_relations entry like '&n is_greater_than &n' evaluates at match time with sigil-bound values \u2014 NOT a fixed string comparison. This is easy to forget when authoring specimens."
  }
}
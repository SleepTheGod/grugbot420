      "text": "\ud83e\udeb5 Grug say hello back! Grug happy to meet you."
    },
    {
      "id": 2,
      "intensity": 1.0,
      "pinned": false,
      "role": "User",
      "text": "What is arithmetic?"
    },
    {
      "id": 3,
      "intensity": 1.0,
      "pinned": false,
      "role": "Engine_Voice",
      "text": "Arithmetic operates on numbers through addition, subtraction, multiplication, and division."

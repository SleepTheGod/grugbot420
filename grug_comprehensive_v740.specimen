  "actions": [
    {
      "trigger_verb": "say",
      "action_type": "dynamic",
      "template": "REPEAT(RESOLVE({{target}}), {{count}})",
      "description": "Say something N times. 'say hello 3 times' \u2192 hello hello hello. RESOLVE first so 'say the date 2 times' works too."
    },
    {
      "trigger_verb": "repeat",
      "action_type": "dynamic",
      "template": "REPEAT(RESOLVE({{target}}), {{count}})",
      "description": "Repeat something N times. 'repeat hello 2 times' \u2192 hello hello. Synonym for SAY."
    },
    {
      "trigger_verb": "count",
      "action_type": "dynamic",
      "template": "COUNT_TO({{count}})",
      "description": "Count from 1 to N. 'count to 5' \u2192 '1, 2, 3, 4, 5'."
    },
    {
      "trigger_verb": "check",
      "action_type": "dynamic",
      "template": "SAY(RESOLVE({{target}}))",
      "description": "Check a reference by resolving it. 'check the date' \u2192 2026-06-13. 'check the time' \u2192 14:30:05."
    },
    {
      "trigger_verb": "tell",
      "action_type": "dynamic",
      "template": "SAY(RESOLVE({{target}}))",
      "description": "Tell me about a reference by resolving it. 'tell the time' \u2192 14:30:05. 'tell the date' \u2192 2026-06-13."
    },
    {
      "trigger_verb": "remind",
      "action_type": "dynamic",
      "template": "IF(HAS({{target}}), SAY(RESOLVE({{target}})), SAY(I don't recall that))",
      "description": "Remind me about something. Only speaks if the reference exists. 'remind me about the date' \u2192 today's date if available."
    },
    {
      "trigger_verb": "announce",
      "action_type": "dynamic",
      "template": "IF(PRESENT(RESOLVE(recent)), SAY(RESOLVE(recent)), SAY(Nothing new to announce))",
      "description": "Announce what's new. Checks recent context. Returns 'Nothing new' if empty."
    },
    {
      "trigger_verb": "recall",
      "action_type": "dynamic",
      "template": "WHEN(PRESENT(RESOLVE(ages ago)), SAY(RESOLVE(ages ago)))",
      "description": "Recall something from deep memory. Silent if no trace exists."
    },
    {
      "trigger_verb": "confirm",
      "action_type": "dynamic",
      "template": "IF(HAS({{target}}), SAY(Yes, I can confirm that), SAY(No, I have no record of that))",
      "description": "Confirm whether a reference exists. 'confirm the date' \u2192 Yes/No."
    },
    {
      "trigger_verb": "compare",
      "action_type": "dynamic",
      "template": "IF(GT({{target}}, 5), SAY(That is a big number), SAY(That is a small number))",
      "description": "Compare a number against 5. 'compare 10' \u2192 big. 'compare 2' \u2192 small."
    },
    {
      "trigger_verb": "verify",
      "action_type": "dynamic",
      "template": "IF(EQUALS({{target}}, yes), SAY(Confirmed!), SAY(Not confirmed))",
      "description": "Verify if target equals 'yes'. 'verify yes' \u2192 Confirmed!."
    },
    {
      "trigger_verb": "search",
      "action_type": "dynamic",
      "template": "SAY(RESOLVE({{target}}))",
      "description": "Search for a compound reference. 'search recent and today' \u2192 resolves both and merges."
    },
    {
      "trigger_verb": "confirm",
      "action_type": "dynamic",
      "template": "SAY(RESOLVE({{target}}))",
      "description": "Confirm a reference value"
    },
    {
      "trigger_verb": "verify",
      "action_type": "dynamic",
      "template": "SAY(RESOLVE({{target}}))",
      "description": "Verify a reference value"
    },
    {
      "trigger_verb": "announce",
      "action_type": "dynamic",
      "template": "SAY(RESOLVE({{target}}))",
      "description": "Announce a reference value"
    },
    {
      "trigger_verb": "remind",
      "action_type": "dynamic",
      "template": "SAY(RESOLVE({{target}}))",
      "description": "Remind about a reference value"
    },
    {
      "trigger_verb": "recall",
      "action_type": "dynamic",
      "template": "SAY(RESOLVE({{target}}))",
      "description": "Recall a reference or recent value"
    },
    {
      "trigger_verb": "search",
      "action_type": "dynamic",
      "template": "SAY(RESOLVE({{target}}))",
      "description": "Search for a reference value"
    },
    {
      "trigger_verb": "compare",
      "action_type": "dynamic",
      "template": "SAY(RESOLVE({{target}}))",
      "description": "Compare reference values"
    },
    {
      "trigger_verb": "summarize",
      "action_type": "static",
      "template": "SUMMARY({{rest}})",
      "description": "Summarize the rest argument"
    },
    {
      "trigger_verb": "describe",
      "action_type": "static",
      "template": "DESCRIPTION({{rest}})",
      "description": "Describe the rest argument"
    },
    {
      "trigger_verb": "evaluate",
      "action_type": "static",
      "template": "EVALUATION({{rest}})",
      "description": "Evaluate the rest argument"
    }
  ],
  "resolve_conflict_mode": "merge",
  "decomposer_config": {
    "compound_pairs": {
      "not only": "but also",
      "either": "or",
      "neither": "nor",
      "both": "and",
      "whether": "or"
    },
    "question_markers": [
